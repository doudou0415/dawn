<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dawn Panel</title>
  <style>
    /* ===== Reset & Base ===== */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body {
      height: 100%;
      overflow: hidden;
    }
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Noto Sans SC", "PingFang SC", "Microsoft YaHei", sans-serif;
      background: #0f0f1a;
      color: #d4d4e8;
      height: 100vh;
      overflow: hidden;
      font-size: 14px;
      line-height: 1.6;
    }

    /* ===== Layout: 左侧栏 | 主区 | 右侧面板 ===== */
    .app-container {
      display: flex;
      height: 100vh;
      max-width: 100vw;
    }

    /* ===== Left Sidebar ===== */
    .left-sidebar {
      width: 240px;
      background: #12122a;
      border-right: 1px solid #1e1e3f;
      display: flex;
      flex-direction: column;
      flex-shrink: 0;
      overflow-y: auto;
    }
    .left-sidebar::-webkit-scrollbar { width: 4px; }
    .left-sidebar::-webkit-scrollbar-thumb { background: #2d2d5a; border-radius: 2px; }

    .left-header {
      padding: 16px;
      border-bottom: 1px solid #1e1e3f;
    }
    .left-header h2 {
      font-size: 14px;
      font-weight: 600;
      color: #a78bfa;
      letter-spacing: 0.5px;
    }
    .left-header .sub {
      font-size: 11px;
      color: #555;
      margin-top: 2px;
    }

    .left-section-title {
      padding: 12px 16px 4px;
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      color: #555;
    }

    .left-item {
      padding: 8px 16px;
      font-size: 13px;
      color: #999;
      cursor: pointer;
      transition: background 0.15s, color 0.15s;
      display: flex;
      align-items: center;
      gap: 8px;
      border-left: 2px solid transparent;
    }
    .left-item:hover {
      background: #1a1a3a;
      color: #ccc;
    }
    .left-item.active {
      background: #1a1a3a;
      color: #a78bfa;
      border-left-color: #a78bfa;
    }
    .left-item .icon {
      width: 18px;
      text-align: center;
      font-size: 14px;
      opacity: 0.6;
    }

    /* ===== Main Area ===== */
    .main-area {
      flex: 1;
      display: flex;
      flex-direction: column;
      min-width: 0;
    }

    /* ===== Header ===== */
    .header {
      background: #14142e;
      padding: 10px 20px;
      border-bottom: 1px solid #1e1e3f;
      display: flex;
      align-items: center;
      gap: 12px;
      flex-shrink: 0;
      min-height: 48px;
    }
    .header h1 {
      font-size: 15px;
      font-weight: 600;
      color: #a78bfa;
    }
    .header .status {
      font-size: 11px;
      color: #4ade80;
      display: flex;
      align-items: center;
      gap: 4px;
    }
    .header .status::before {
      content: '';
      width: 7px;
      height: 7px;
      background: #4ade80;
      border-radius: 50%;
      display: inline-block;
      box-shadow: 0 0 6px rgba(74,222,128,0.5);
    }
    .header-version {
      font-size: 11px;
      color: #444;
      margin-left: auto;
    }

    /* ===== Messages ===== */
    .messages {
      flex: 1;
      overflow-y: auto;
      padding: 16px 20px;
      display: flex;
      flex-direction: column;
      gap: 10px;
      scroll-behavior: smooth;
    }
    .messages::-webkit-scrollbar { width: 5px; }
    .messages::-webkit-scrollbar-track { background: transparent; }
    .messages::-webkit-scrollbar-thumb { background: #2d2d5a; border-radius: 3px; }

    .message {
      padding: 14px 18px;
      border-radius: 10px;
      max-width: 88%;
      line-height: 1.7;
      font-size: 14px;
      word-wrap: break-word;
      overflow-wrap: break-word;
    }
    .message strong.msg-label {
      display: block;
      font-size: 11px;
      color: #666;
      margin-bottom: 6px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      font-weight: 600;
    }
    .message-user {
      background: #1e1e42;
      align-self: flex-end;
      border-bottom-right-radius: 4px;
    }
    .message-assistant {
      background: #16163a;
      align-self: flex-start;
      border-bottom-left-radius: 4px;
    }

    /* ===== Markdown Body ===== */
    .message-body h2 { font-size: 16px; color: #a78bfa; margin: 10px 0 5px; }
    .message-body h3 { font-size: 14px; color: #c4b5fd; margin: 8px 0 4px; }
    .message-body h4 { font-size: 13px; color: #ddd6fe; margin: 6px 0 3px; }
    .message-body p { margin: 6px 0; }
    .message-body strong { display: inline; font-size: inherit; color: inherit; text-transform: none; letter-spacing: normal; font-weight: 600; }
    .message-body ul, .message-body ol { margin: 6px 0; padding-left: 22px; }
    .message-body li { margin: 3px 0; }
    .message-body a { color: #818cf8; text-decoration: none; }
    .message-body a:hover { text-decoration: underline; }
    .message-body blockquote {
      border-left: 3px solid #a78bfa;
      padding: 6px 12px;
      color: #999;
      margin: 8px 0;
      background: rgba(167,139,250,0.04);
      border-radius: 0 4px 4px 0;
    }
    .message-body hr { border: none; border-top: 1px solid #2d2d5a; margin: 12px 0; }
    .message-body table { border-collapse: collapse; margin: 8px 0; width: 100%; font-size: 13px; }
    .message-body th, .message-body td { border: 1px solid #2d2d5a; padding: 6px 10px; text-align: left; }
    .message-body th { background: #14142e; color: #a78bfa; font-weight: 600; }
    .message-body code {
      background: #1a1a30;
      padding: 2px 6px;
      border-radius: 4px;
      font-family: "JetBrains Mono", "Fira Code", "Consolas", monospace;
      font-size: 13px;
      color: #f472b6;
    }
    .message-body pre {
      background: #0a0a1a;
      border: 1px solid #1e1e3f;
      border-radius: 8px;
      margin: 10px 0;
      position: relative;
      overflow: hidden;
    }
    .message-body pre .code-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 6px 12px;
      background: #12122a;
      border-bottom: 1px solid #1e1e3f;
      font-size: 11px;
      color: #666;
    }
    .message-body pre .code-header .lang-label {
      color: #666;
    }
    .message-body pre .code-header .copy-btn {
      background: transparent;
      border: 1px solid #2d2d5a;
      color: #888;
      padding: 2px 10px;
      border-radius: 4px;
      font-size: 11px;
      cursor: pointer;
      transition: all 0.15s;
      font-family: inherit;
    }
    .message-body pre .code-header .copy-btn:hover {
      background: #2d2d5a;
      color: #d4d4e8;
      border-color: #3d3d6a;
    }
    .message-body pre .code-header .copy-btn.copied {
      background: #1a4730;
      border-color: #4ade80;
      color: #4ade80;
    }
    .message-body pre code {
      display: block;
      padding: 14px 16px;
      background: transparent;
      color: #d4d4e8;
      font-size: 13px;
      line-height: 1.6;
      overflow-x: auto;
      white-space: pre;
      word-wrap: normal;
      font-family: "JetBrains Mono", "Fira Code", "Consolas", monospace;
    }
    /* FIX: 代码块内如果内容超宽，用滚动而不是撑破容器 */
    .message-body pre code {
      max-width: 100%;
    }

    /* ===== Syntax Highlight ===== */
    .hljs-keyword { color: #c678dd; }
    .hljs-string { color: #98c379; }
    .hljs-number { color: #d19a66; }
    .hljs-comment { color: #5c6370; font-style: italic; }
    .hljs-function { color: #61afef; }
    .hljs-built_in { color: #56b6c2; }
    .hljs-attr { color: #e5c07b; }
    .hljs-params { color: #abb2bf; }
    .hljs-literal { color: #56b6c2; }
    .hljs-title { color: #61afef; }
    .hljs-property { color: #e5c07b; }
    .hljs-punctuation { color: #abb2bf; }

    /* ===== Thinking Animation ===== */
    .thinking-dots {
      display: inline-flex;
      align-items: center;
      gap: 3px;
      font-size: 30px;
      color: #a78bfa;
      line-height: 1;
      height: 24px;
    }
    .thinking-dots span {
      animation: bounce 1.4s infinite ease-in-out both;
      display: inline-block;
    }
    .thinking-dots span:nth-child(1) { animation-delay: -0.32s; }
    .thinking-dots span:nth-child(2) { animation-delay: -0.16s; }
    .thinking-dots span:nth-child(3) { animation-delay: 0s; }
    @keyframes bounce {
      0%, 80%, 100% { transform: scale(0); opacity: 0.3; }
      40% { transform: scale(1); opacity: 1; }
    }
    .loading-message {
      animation: pulse 1.5s ease-in-out infinite;
    }
    @keyframes pulse {
      0%, 100% { opacity: 0.6; }
      50% { opacity: 1; }
    }

    /* ===== Input Area ===== */
    .input-area {
      background: #14142e;
      border-top: 1px solid #1e1e3f;
      padding: 12px 20px 16px;
      display: flex;
      gap: 10px;
      align-items: flex-end;
      flex-shrink: 0;
    }
    .input-area textarea {
      flex: 1;
      background: #0f0f1a;
      border: 1px solid #2d2d5a;
      border-radius: 10px;
      padding: 12px 16px;
      color: #d4d4e8;
      font-size: 14px;
      font-family: inherit;
      resize: none;
      outline: none;
      min-height: 48px;
      max-height: 240px;
      line-height: 1.5;
      transition: border-color 0.2s;
    }
    .input-area textarea:focus {
      border-color: #7c3aed;
      box-shadow: 0 0 0 1px rgba(124,58,237,0.15);
    }
    .input-area textarea::placeholder {
      color: #555;
    }
    .input-area textarea:disabled {
      opacity: 0.4;
    }

    .input-area button {
      background: #7c3aed;
      color: white;
      border: none;
      border-radius: 10px;
      padding: 12px 24px;
      font-size: 14px;
      font-weight: 500;
      cursor: pointer;
      transition: background 0.2s, transform 0.1s;
      white-space: nowrap;
      min-height: 48px;
    }
    .input-area button:hover:not(:disabled) {
      background: #6d28d9;
    }
    .input-area button:active:not(:disabled) {
      transform: scale(0.97);
    }
    .input-area button:disabled {
      opacity: 0.4;
      cursor: not-allowed;
    }

    /* ===== Right Side Panel ===== */
    .side-panel {
      width: 300px;
      background: #12122a;
      border-left: 1px solid #1e1e3f;
      overflow-y: auto;
      flex-shrink: 0;
      display: flex;
      flex-direction: column;
    }
    .side-panel::-webkit-scrollbar { width: 4px; }
    .side-panel::-webkit-scrollbar-thumb { background: #2d2d5a; border-radius: 2px; }

    .panel-section {
      padding: 14px 16px;
      border-bottom: 1px solid #1e1e3f;
    }
    .panel-section:last-child {
      border-bottom: none;
    }

    .panel-section h3 {
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.6px;
      color: #a78bfa;
      margin-bottom: 10px;
      font-weight: 600;
    }

    .panel-section .content {
      font-size: 13px;
      line-height: 1.6;
      color: #bbb;
    }

    /* Model Status */
    .model-status {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 4px 0;
    }
    .model-status .dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      flex-shrink: 0;
    }
    .model-status .dot.online { background: #4ade80; box-shadow: 0 0 6px rgba(74,222,128,0.4); }
    .model-status .dot.offline { background: #ef4444; box-shadow: 0 0 6px rgba(239,68,68,0.4); }

    .model-name {
      font-weight: 500;
      color: #d4d4e8;
    }
    .model-status-text {
      font-size: 11px;
      color: #666;
      margin-left: auto;
    }

    /* Review Score */
    .score-large {
      text-align: center;
      padding: 4px 0 8px;
    }

    .issue {
      padding: 4px 8px;
      margin: 3px 0;
      border-radius: 4px;
      font-size: 12px;
      line-height: 1.4;
    }
    .issue.error { background: rgba(244,67,54,0.12); color: #ef5350; border-left: 2px solid #ef5350; }
    .issue.warning { background: rgba(255,152,0,0.12); color: #ff9800; border-left: 2px solid #ff9800; }
    .issue.info { background: rgba(33,150,243,0.12); color: #42a5f5; border-left: 2px solid #42a5f5; }

    /* Evolution Summary */
    .evo-item {
      padding: 4px 0;
      font-size: 12px;
      color: #aaa;
      border-bottom: 1px solid rgba(255,255,255,0.03);
    }
    .evo-item:last-child { border-bottom: none; }
    .evo-item .evo-label {
      color: #7c3aed;
      font-weight: 500;
    }

    /* Collapsible Section */
    .collapsible-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      cursor: pointer;
      user-select: none;
    }
    .collapsible-header:hover {
      color: #c4b5fd;
    }
    .collapsible-header .arrow {
      font-size: 10px;
      color: #666;
      transition: transform 0.2s;
    }
    .collapsible-header .arrow.open {
      transform: rotate(90deg);
    }
    .collapsible-body {
      overflow: hidden;
      transition: max-height 0.25s ease, opacity 0.2s ease;
      max-height: 300px;
      opacity: 1;
    }
    .collapsible-body.closed {
      max-height: 0;
      opacity: 0;
      margin: 0;
    }

    .setting-row {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 6px 0;
      font-size: 13px;
    }
    .setting-row label {
      color: #999;
      min-width: 60px;
      flex-shrink: 0;
    }
    .setting-row select {
      flex: 1;
      background: #0f0f1a;
      border: 1px solid #2d2d5a;
      border-radius: 6px;
      padding: 6px 10px;
      color: #d4d4e8;
      font-size: 13px;
      font-family: inherit;
      outline: none;
      cursor: pointer;
    }
    .setting-row select:focus {
      border-color: #7c3aed;
    }
    .setting-row input[type="password"] {
      flex: 1;
      background: #0f0f1a;
      border: 1px solid #2d2d5a;
      border-radius: 6px;
      padding: 6px 10px;
      color: #d4d4e8;
      font-size: 13px;
      font-family: inherit;
      outline: none;
    }
    .setting-row input[type="password"]:focus {
      border-color: #7c3aed;
    }

    /* Memory Items */
    .mem-item {
      display: flex;
      flex-direction: column;
      gap: 2px;
      padding: 5px 0;
      border-bottom: 1px solid rgba(255,255,255,0.04);
    }
    .mem-item:last-child { border-bottom: none; }
    .mem-key {
      font-size: 11px;
      color: #7c3aed;
      font-weight: 500;
    }
    .mem-val {
      font-size: 12px;
      color: #bbb;
      word-break: break-all;
    }

    /* Empty state */
    .empty-state {
      color: #555;
      font-size: 12px;
      font-style: italic;
    }

    /* ===== Message Copy Button ===== */
    .msg-copy-row {
      display: flex;
      justify-content: flex-end;
      margin-top: 6px;
    }
    .msg-copy-btn {
      background: transparent;
      border: 1px solid #2d2d5a;
      color: #888;
      padding: 2px 10px;
      border-radius: 4px;
      font-size: 11px;
      cursor: pointer;
      transition: all 0.15s;
      font-family: inherit;
      opacity: 0;
      pointer-events: none;
    }
    .message:hover .msg-copy-btn {
      opacity: 1;
      pointer-events: auto;
    }
    .msg-copy-btn:hover {
      background: #2d2d5a;
      color: #d4d4e8;
      border-color: #3d3d6a;
    }
    .msg-copy-btn.copied {
      background: #1a4730;
      border-color: #4ade80;
      color: #4ade80;
    }

    /* ===== Inline code fix for message body ===== */
    .message-body p code,
    .message-body li code {
      white-space: nowrap;
    }
  </style>
</head>
<body>
  <div class="app-container">
    <!-- 左侧栏 -->
    <div class="left-sidebar">
      <div class="left-header">
        <h2>Dawn Panel</h2>
        <div class="sub">新架构版 · v1.0</div>
      </div>
      <div class="left-section-title">对话</div>
      <div class="left-item active"><span class="icon">💬</span> 当前对话</div>
      <div class="left-item"><span class="icon">📂</span> 项目文件</div>
      <div class="left-item"><span class="icon">⚙️</span> 设置</div>
      <div style="flex:1"></div>
      <div class="left-item" style="border-top:1px solid #1e1e3f;border-left-color:transparent">
        <span class="icon">🔄</span> 刷新
      </div>
    </div>

    <!-- 主区域 -->
    <div class="main-area">
      <div class="header">
        <h1>DawnNew</h1>
        <span class="status">已连接</span>
        <span class="header-version">Engine v2.0</span>
      </div>

      <div class="messages" id="messages"></div>

      <div class="input-area">
        <textarea id="input" placeholder="输入消息... (Enter 发送, Shift+Enter 换行)" rows="1"></textarea>
        <button id="send-btn">发送</button>
      </div>
    </div>

    <!-- 右侧面板 -->
    <div class="side-panel" id="side-panel">
      <!-- 模型状态 -->
      <div class="panel-section">
        <h3>模型</h3>
        <div class="content">
          <div class="model-status">
            <span class="dot online" id="model-dot"></span>
            <span class="model-name" id="model-name">deepseek-v4</span>
            <span class="model-status-text" id="model-status-text">在线</span>
          </div>
        </div>
      </div>

      <!-- 审查评分 -->
      <div class="panel-section">
        <h3>审查评分</h3>
        <div class="content score-large" id="review-score">
          <span style="color:#555;font-size:13px">等待审查...</span>
        </div>
        <div class="content" id="review-issues"></div>
      </div>

      <!-- 自进化总结 (可折叠) -->
      <div class="panel-section">
        <div class="collapsible-header" id="evo-toggle">
          <h3 style="margin-bottom:0">自进化总结</h3>
          <span class="arrow open" id="evo-arrow">▶</span>
        </div>
        <div class="collapsible-body" id="evo-body">
          <div class="content" id="evolution-summary" style="margin-top:10px">
            <span class="empty-state">暂无数据</span>
          </div>
        </div>
      </div>

      <!-- 模型选择 / KEY (可折叠) -->
      <div class="panel-section">
        <div class="collapsible-header" id="config-toggle">
          <h3 style="margin-bottom:0">高级配置</h3>
          <span class="arrow open" id="config-arrow">▶</span>
        </div>
        <div class="collapsible-body" id="config-body">
          <div class="content" style="margin-top:10px">
            <div class="setting-row">
              <label>模型</label>
              <select id="model-select">
                <option value="deepseek-v4">deepseek-v4 (默认)</option>
                <option value="gpt-4o">GPT-4o</option>
                <option value="claude-sonnet">Claude Sonnet</option>
              </select>
            </div>
            <div class="setting-row">
              <label>API Key</label>
              <input type="password" id="api-key-input" placeholder="输入 API Key...">
            </div>
          </div>
        </div>
      </div>

      <!-- 权限分级 (可折叠) -->
      <div class="panel-section">
        <div class="collapsible-header" id="perm-toggle">
          <h3 style="margin-bottom:0">权限分级</h3>
          <span class="arrow open" id="perm-arrow">▶</span>
        </div>
        <div class="collapsible-body" id="perm-body">
          <div class="content" style="margin-top:10px">
            <div id="permission-section">
              <div style="display:flex;align-items:center;gap:12px;margin-bottom:8px">
                <span style="font-size:11px;color:#666;min-width:24px">1</span>
                <input type="range" class="permission-slider" min="1" max="5" step="1" value="3" style="flex:1;accent-color:#7c3aed;height:4px;cursor:pointer">
                <span style="font-size:11px;color:#666;min-width:24px">5</span>
              </div>
              <div style="display:flex;justify-content:space-between;align-items:center">
                <span class="permission-label" style="color:#a78bfa;font-weight:600;font-size:13px">增强</span>
                <span style="font-size:11px;color:#555">当前: <span id="perm-level-display">3</span></span>
              </div>
              <div class="permission-desc" style="font-size:11px;color:#777;margin-top:4px;line-height:1.4">
                可运行 shell 命令
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- 记忆状态 -->
      <div class="panel-section">
        <h3>记忆状态</h3>
        <div class="content" id="memory-state">
          <span class="empty-state">加载中...</span>
        </div>
      </div>

      <!-- 搜索结果 -->
      <div class="panel-section">
        <h3>搜索结果</h3>
        <div class="content" id="search-results">
          <span class="empty-state">无</span>
        </div>
      </div>
    </div>
  </div>

