{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Dawn",
  "mainBinaryName": "Dawn",
  "version": "1.0.0",
  "identifier": "dev.dawn.panel",
  "build": {
    "beforeDevCommand": "bun run build",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": ".."
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Dawn",
        "width": 1280,
        "height": 820,
        "resizable": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      }
    }
  }
}
