{
  "name": "@dawn/cli",
  "version": "1.0.0",
  "description": "Dawn - Self-Evolving AI Coding Assistant",
  "type": "module",
  "main": "src/cli/index.ts",
  "scripts": {
    "dev": "bun src/cli/index.ts",
    "start": "bun src/cli/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "build": "bun build src/cli/index.ts --outdir ./dist --target bun",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist && find src -name '*.js' -o -name '*.js.map' -o -name '*.d.ts' -o -name '*.d.ts.map' | xargs rm -f",
    "build:all": "bun run build && cd ../DawnPanel && bun run build",
    "release": "bun run build:all && bun run test",
    "tauri:dev": "cd ../DawnPanel && bun run tauri dev",
    "lint": "eslint src/",
    "lint:fix": "eslint --fix src/",
    "format": "prettier --write 'src/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts'"
  },
  "dependencies": {
    "@dawn/core": "workspace:*",
    "@dawn/evolution": "workspace:*",
    "@dawn/memory": "workspace:*",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "bun-types": "^1.3.13",
    "eslint": "^9.0.0",
    "prettier": "^3.4.0",
    "vitest": "^3.1.0"
  },
  "workspaces": [
    "packages/*"
  ]
}
