# ===== LLM 配置（当前使用 DeepSeek）=====
# 从 https://platform.deepseek.com/api_keys 获取
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-v4-flash
DEEPSEEK_API_KEY=sk-your-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# ===== 备用模型（可选）=====
DEFAULT_MODEL=deepseek-v4-pro

# ===== 通用参数 =====
API_TIMEOUT_MS=300000
LLM_TEMPERATURE=0.1
LLM_ENABLE_THINKING=0
LLM_MAX_OUTPUT_TOKENS=4096

# ===== 向量搜索配置 =====
VECTOR_SEARCH_ENABLED=true
OLLAMA_HOST=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text

# ===== 优化开关 =====
TOOL_CALL_CACHE_ENABLED=true
CONTEXT_COMPRESSION_ENABLED=true
INDEXER_INCREMENTAL=true
ERROR_AUTO_FIX=true

# ===== 服务器配置 =====
PORT=3001
HOST=127.0.0.1

# ===== Dawn 配置 =====
LOG_LEVEL=info
AUTO_FORGET_INTERVAL_MS=1800000
EVOLUTION_TEMP_DIR=./.dawn-evolution-tmp
