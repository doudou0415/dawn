# ===== API 配置 =====
# 从 https://platform.deepseek.com/api_keys 获取
DEEPSEEK_API_KEY=sk-your-api-key-here

# API 地址（可选，默认使用 DeepSeek）
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ===== LLM 配置（可选）=====
# OpenAI 兼容 API（可选，用于测试）
OPENAI_API_KEY=
OPENAI_BASE_URL=

# LLM Provider (deepseek | openai)
LLM_PROVIDER=deepseek

# 模型参数
LLM_MODEL=deepseek-chat
MAX_TOKENS=8192
TEMPERATURE=0.7

# ===== 服务器配置 =====
PORT=3001
HOST=127.0.0.1

# ===== Dawn 配置 =====
# 日志级别: debug | info | warn | error
LOG_LEVEL=info

# 记忆自动遗忘间隔（毫秒），默认 1800000（30 分钟）
AUTO_FORGET_INTERVAL_MS=1800000

# Evolution 沙箱临时目录
EVOLUTION_TEMP_DIR=./.dawn-evolution-tmp
